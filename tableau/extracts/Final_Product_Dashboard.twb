  <worksheets>
    <worksheet name='Delay Distribution'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='11'>Order Deliveries Skew Early, Though Late Deliveries Remain a Consistent Risk</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='tableau_orders.csv (Multiple Connections)' name='federated.0xmezhx19v5kkn1b9z1be1pp6l7k' />
          </datasources>
          <datasource-dependencies datasource='federated.0xmezhx19v5kkn1b9z1be1pp6l7k'>
            <column caption='Label' datatype='string' name='[Calculation_3232898091646985]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [delivery_delay_days] &gt; 0 THEN &quot;Late&quot;&#13;&#10;ELSE &quot;Early&quot;&#13;&#10;END' />
            </column>
            <column aggregation='None' caption='Delivery Delay Days ' datatype='integer' name='[Delivery Delay Days (bin)]' role='dimension' type='ordinal'>
              <calculation class='bin' decimals='0' formula='[delivery_delay_days]' peg='0' size='4' />
            </column>
            <column caption='Delivery Delay Days' datatype='integer' name='[delivery_delay_days]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_3232898091646985]' derivation='None' name='[none:Calculation_3232898091646985:nk]' pivot='key' type='nominal' />
            <column-instance column='[Delivery Delay Days (bin)]' derivation='None' name='[none:Delivery Delay Days (bin):qk]' pivot='key' type='quantitative' />
            <column-instance column='[delivery_delay_days]' derivation='Count' name='[pcto:cnt:delivery_delay_days:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' type='PctTotal' />
            </column-instance>
          </datasource-dependencies>
          <filter class='quantitative' column='[federated.0xmezhx19v5kkn1b9z1be1pp6l7k].[none:Delivery Delay Days (bin):qk]' included-values='in-range'>
            <min>-10</min>
            <max>3</max>
          </filter>
          <filter class='quantitative' column='[federated.0xmezhx19v5kkn1b9z1be1pp6l7k].[pcto:cnt:delivery_delay_days:qk]' included-values='non-null' />
