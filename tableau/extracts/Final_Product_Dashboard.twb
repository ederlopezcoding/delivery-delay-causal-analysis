            <column caption='Bad Reivew %' datatype='string' name='[Calculation_3232898130108426]' role='measure' type='nominal'>
              <calculation class='tableau' formula='STR(ROUND(AVG([low_review]) * 100, 1)) + &quot;%&quot;' />
